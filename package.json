{
  "name": "appfabrik-app-base",
  "version": "1.0.0",
  "description": "AppFabrik White-Label React Native/Expo Template",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform all",
    "setup:tenant": "./scripts/setup-tenant.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nozbe/watermelondb": "^0.27.1",
