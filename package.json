    "axios": "^1.7.0",
    "expo": "~54.0.33",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-updates": "~0.26.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "typescript": "~5.7.0"
  },
  "keywords": [
    "appfabrik",
    "expo",
    "react-native",
